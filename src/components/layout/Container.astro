---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  class?: string;
}
const { size = 'lg', class: cls = '' } = Astro.props;
const widths = {
  sm:   'max-w-2xl',
  md:   'max-w-4xl',
  lg:   'max-w-6xl',
  xl:   'max-w-7xl',
  full: 'max-w-none'
} as const;
---
<div class:list={['mx-auto w-full px-5 sm:px-8', widths[size], cls]}>
  <slot />
</div>
