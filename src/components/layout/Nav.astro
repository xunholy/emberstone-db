---
import Container from './Container.astro';
import SearchTrigger from '~/components/search/SearchTrigger.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;

const links = [
  { href: `${base}/quests`,  label: 'Quests'  },
  { href: `${base}/items`,   label: 'Items'   },
  { href: `${base}/npcs`,    label: 'NPCs'    },
  { href: `${base}/spells`,  label: 'Spells'  },
  { href: `${base}/zones`,   label: 'Zones'   },
  { href: `${base}/custom`,  label: 'Emberstone', emphasis: true }
];

function isActive(href: string) {
  // strict prefix match — `/db/quests` matches `/db/quests/4322`
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header
  class="sticky top-0 z-40 border-b border-ash-800/80 bg-bg/70 backdrop-blur-xl
         supports-[backdrop-filter]:bg-bg/55"
>
  <Container size="xl">
    <div class="flex h-14 items-center gap-4">
      <a href={base + '/'} class="flex items-center gap-2.5 group" aria-label="Emberstone Database — home">
        <span
          class="relative inline-flex h-7 w-7 items-center justify-center
                 rounded-md bg-gold-gradient text-bg shadow-glow
                 group-hover:shadow-glow-lg transition-shadow duration-500 ease-out-expo"
          aria-hidden="true"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
            <path d="M12 2 4 7v6.5C4 18.2 7.6 22 12 22s8-3.8 8-8.5V7l-8-5Z"/>
          </svg>
        </span>
        <span class="text-sm font-medium tracking-tight">
          Emberstone <span class="text-ember-400">Database</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1 ml-2" aria-label="Primary">
        {links.map(l => (
          <a
            href={l.href}
            aria-current={isActive(l.href) ? 'page' : undefined}
            class:list={[
              'relative px-3 py-1.5 text-sm rounded-md transition-colors',
              isActive(l.href)
                ? 'text-ember-200'
                : 'text-ash-300 hover:text-ash-50',
              l.emphasis && !isActive(l.href) && 'text-ember-300/90 hover:text-ember-200'
            ]}
          >
            {l.label}
            {isActive(l.href) && (
              <span
                class="absolute -bottom-px left-3 right-3 h-px bg-gradient-to-r
                       from-transparent via-ember-400 to-transparent"
                aria-hidden="true"
              />
            )}
          </a>
        ))}
      </nav>

      <div class="ml-auto flex items-center gap-2">
        <SearchTrigger />
        <a
          href="https://emberstone.owncloud.ai"
          class="hidden sm:inline-flex items-center gap-1.5 text-xs text-ash-300
                 hover:text-ember-300 transition-colors"
        >
          Portal
          <svg class="h-3 w-3 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>
  <!-- hairline gold glow under the nav for atmosphere -->
  <div class="ember-divider opacity-70" aria-hidden="true"/>
</header>
