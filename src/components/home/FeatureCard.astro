---
interface Props {
  title: string;
  description: string;
  href: string;
  /** Lucide-equivalent SVG path data (24x24). */
  iconPath: string;
  /** Lower-right accent count or label. */
  meta?: string;
  /** Emberstone-specific styling (extra glow). */
  ember?: boolean;
}
const { title, description, href, iconPath, meta, ember = false } = Astro.props;
---
<a
  href={href}
  class:list={[
    'group block relative overflow-hidden rounded-lg border bg-bg-surface/70 p-6',
    'transition-all duration-500 ease-out-expo',
    'hover:-translate-y-1',
    ember
      ? 'border-ember-800/70 hover:border-ember-500/80 hover:shadow-glow-lg'
      : 'border-ash-800 hover:border-ember-800 hover:shadow-glow'
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div
      class:list={[
        'inline-flex h-10 w-10 items-center justify-center rounded-md',
        'transition-all duration-500 ease-out-expo',
        ember
          ? 'bg-gold-gradient text-bg shadow-glow'
          : 'bg-ash-800/60 text-ember-300 group-hover:bg-ember-900/60'
      ]}
      aria-hidden="true"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d={iconPath} stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    {meta && (
      <span class="text-[10px] uppercase tracking-widest text-ash-500 font-mono">
        {meta}
      </span>
    )}
  </div>
  <h3
    class:list={[
      'mt-4 text-base font-semibold tracking-tight transition-colors',
      ember ? 'text-ember-100' : 'text-ash-50 group-hover:text-ember-100'
    ]}
  >
    {title}
  </h3>
  <p class="mt-1.5 text-sm leading-relaxed text-ash-400">
    {description}
  </p>

  <div class="mt-4 flex items-center gap-1 text-xs text-ember-400 opacity-60 group-hover:opacity-100 transition-opacity">
    Browse
    <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5"
         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>

  <!-- pointer-driven sheen -->
  <div
    class="pointer-events-none absolute -inset-px rounded-lg opacity-0 group-hover:opacity-100
           transition-opacity duration-700
           bg-[radial-gradient(circle_at_var(--mx,_50%)_var(--my,_50%),_rgba(201,168,76,0.10),_transparent_55%)]"
    aria-hidden="true"
  />
</a>
