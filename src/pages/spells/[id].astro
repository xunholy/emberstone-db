---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/layout/Container.astro';
import EntityHeader from '~/components/entities/EntityHeader.astro';
import WowheadLink from '~/components/entities/WowheadLink.astro';
import { getSpell } from '~/lib/db/data';

export const prerender = false;
const { id } = Astro.params;
const spell = getSpell(Number(id));
if (!spell) return Astro.redirect('/db/404');
---
<BaseLayout title={`${spell.name} — Spell #${spell.id} — Emberstone Database`}>
  <Container size="lg">
    <EntityHeader
      kind="Spell"
      id={spell.id}
      name={spell.name}
      level={spell.level ? { min: spell.level } : undefined}
    />
    <div class="mt-4 max-w-2xl space-y-6">
      {spell.description && (
        <p class="text-ash-300 leading-relaxed">{spell.description}</p>
      )}
      <div class="rounded-lg border border-ash-800 bg-bg-surface/80 p-5 text-sm">
        <dl class="grid sm:grid-cols-2 gap-x-6 gap-y-2">
          <div class="flex justify-between"><dt class="text-ash-500">Level</dt><dd>{spell.level || '—'}</dd></div>
          <div class="flex justify-between"><dt class="text-ash-500">Class mask</dt><dd class="font-mono">{spell.classMask}</dd></div>
          <div class="flex justify-between"><dt class="text-ash-500">School mask</dt><dd class="font-mono">{spell.schoolMask}</dd></div>
          <div class="flex justify-between"><dt class="text-ash-500">Range idx</dt><dd class="font-mono">{spell.rangeIndex}</dd></div>
        </dl>
      </div>
      <div class="text-xs text-ash-500 flex items-center gap-3">
        <WowheadLink kind="spell" id={spell.id}>View on Wowhead</WowheadLink>
        <span>·</span>
        <a href="/db/spells" class="hover:text-ember-300">← All spells</a>
      </div>
    </div>
  </Container>
</BaseLayout>
