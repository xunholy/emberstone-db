---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/layout/Container.astro';
import EntityList from '~/components/entities/EntityList.astro';
import { listItems } from '~/lib/db/data';
import { QUALITY_NAME } from '~/lib/quality';

export const prerender = false;

const PER_PAGE = 50;
const all = listItems().slice().sort((a, b) => (b.itemLevel || 0) - (a.itemLevel || 0) || a.entry - b.entry);
const totalPages = Math.max(1, Math.ceil(all.length / PER_PAGE));
const pageParam = Number(Astro.url.searchParams.get('page') ?? '1');
const page = Math.min(Math.max(1, pageParam), totalPages);
const start = (page - 1) * PER_PAGE;
const rows = all.slice(start, start + PER_PAGE).map(i => ({
  id: i.entry,
  name: i.name,
  meta: `${QUALITY_NAME[(i.quality as 0)] ?? 'Common'} · iLvl ${i.itemLevel || '?'}`,
  level: i.requiredLevel,
  quality: i.quality,
  emberstoneCustom: i.emberstoneCustom
}));
---
<BaseLayout title={`Items · page ${page} — Emberstone Database`}>
  <Container size="lg" class="mt-10">
    <h1 class="font-heading text-4xl tracking-tight text-ash-50">Items</h1>
    <p class="mt-2 text-ash-300 max-w-2xl">
      Weapons, armor, recipes, consumables, quest items — anything that sits in a
      character's inventory. Sorted by item level. Use search (<kbd class="px-1.5 py-0.5 text-[10px] rounded bg-bg-inset border border-ember-500/[0.08] font-mono">⌘ K</kbd>)
      to filter by name across all {all.length.toLocaleString()} entries.
    </p>
    <div class="mt-8">
      <EntityList
        kind="items"
        rows={rows}
        title="All items · sorted by item level"
        total={all.length}
        page={page}
        totalPages={totalPages}
        hrefBase="/db/items"
      />
    </div>
  </Container>
</BaseLayout>
