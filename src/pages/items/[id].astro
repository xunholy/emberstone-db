---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/layout/Container.astro';
import EntityHeader from '~/components/entities/EntityHeader.astro';
import SideMeta from '~/components/entities/SideMeta.astro';
import WowheadLink from '~/components/entities/WowheadLink.astro';
import { listItems, getItem } from '~/lib/db/data';
import { formatMoney } from '~/lib/format';
import { QUALITY_NAME, qualityTextClass, qualityGlowStyle } from '~/lib/quality';

export const prerender = true;

export async function getStaticPaths() {
  return listItems().map(i => ({ params: { id: String(i.entry) } }));
}

const { id } = Astro.params;
const item = getItem(Number(id));
if (!item) {
  return Astro.redirect('/db/404');
}
const quality = item.quality as 0 | 1 | 2 | 3 | 4 | 5 | 6;
const qualityName = QUALITY_NAME[quality] ?? 'Common';
const isEmberstoneCustom = !!item.emberstoneCustom || (item.entry >= 190000 && item.entry < 200000);
---

<BaseLayout
  title={`${item.name} — Item #${item.entry} — Emberstone Database`}
  description={item.description?.slice(0, 160) || `${qualityName} item ${item.name}.`}
>
  <Container size="lg">
    <EntityHeader
      kind="Item"
      id={item.entry}
      name={item.name}
      emberstoneCustom={isEmberstoneCustom}
    />

    <div class="grid lg:grid-cols-[1fr,18rem] gap-10">
      <article class="space-y-8">
        <!-- Rarity-tinted hero card mimicking the in-game tooltip frame -->
        <div
          class={`rounded-lg border bg-bg-surface/70 p-6 transition-all duration-500`}
          style={qualityGlowStyle(quality)}
        >
          <div class="flex items-baseline justify-between gap-4">
            <div class={`text-xl font-medium ${qualityTextClass(quality)}`}>{item.name}</div>
            <span class="text-[10px] uppercase tracking-widest text-ash-500 font-mono">#{item.entry}</span>
          </div>
          <div class="mt-1 text-xs text-ash-500 uppercase tracking-widest">{qualityName}</div>
          {item.description && (
            <p class="mt-4 text-sm italic text-ash-300 leading-relaxed">"{item.description}"</p>
          )}
          <dl class="mt-5 grid sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
            <div class="flex justify-between"><dt class="text-ash-500">Item level</dt><dd class="text-ash-100">{item.itemLevel || '—'}</dd></div>
            <div class="flex justify-between"><dt class="text-ash-500">Required level</dt><dd class="text-ash-100">{item.requiredLevel || '—'}</dd></div>
            <div class="flex justify-between"><dt class="text-ash-500">Stackable</dt><dd class="text-ash-100">{item.stackable > 1 ? `${item.stackable}` : 'No'}</dd></div>
            <div class="flex justify-between"><dt class="text-ash-500">Sell price</dt><dd class="text-ash-100">{item.sellPrice ? formatMoney(item.sellPrice) : '—'}</dd></div>
            <div class="flex justify-between"><dt class="text-ash-500">Buy price</dt><dd class="text-ash-100">{item.buyPrice ? formatMoney(item.buyPrice) : '—'}</dd></div>
            <div class="flex justify-between"><dt class="text-ash-500">Display ID</dt><dd class="text-ash-100 font-mono">{item.displayId}</dd></div>
          </dl>
        </div>
      </article>

      <SideMeta
        title="Item metadata"
        rows={[
          { label: 'Entry',     value: item.entry, mono: true },
          { label: 'Quality',   value: qualityName },
          { label: 'Class',     value: item.class },
          { label: 'Subclass',  value: item.subclass },
          { label: 'Inv slot',  value: item.inventoryType },
          { label: 'Flags',     value: item.flags },
          ...(isEmberstoneCustom ? [{ label: 'Source', value: 'Emberstone' }] : [])
        ]}
      />
    </div>

    <div class="mt-12 flex items-center gap-3 text-xs text-ash-500">
      {!isEmberstoneCustom && (
        <>
          <WowheadLink kind="item" id={item.entry}>View on Wowhead</WowheadLink>
          <span>·</span>
        </>
      )}
      <a href="/db/items" class="hover:text-ember-300">← All items</a>
    </div>
  </Container>
</BaseLayout>
