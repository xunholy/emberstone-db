// 10–40-man raids.
const RAIDS: Instance[] = [
  { id: 1583, name: 'Upper Blackrock Spire',         lvl: '60', size: 10, hint: 'Searing Gorge — 10-man raid post-1.10' },
  { id: 2677, name: 'Blackwing Lair',                lvl: '60', size: 40, hint: 'inside Blackrock Mountain — Nefarian' },
  { id: 2159, name: "Onyxia's Lair",                 lvl: '60', size: 40, hint: 'Dustwallow Marsh entrance' },
  { id: 2717, name: 'Molten Core',                   lvl: '60', size: 40, hint: 'inside Blackrock Mountain — Ragnaros' },
  { id: 1977, name: "Zul'Gurub",                     lvl: '60', size: 20, hint: 'Stranglethorn Vale — Hakkar' },
  { id: 3429, name: "Ruins of Ahn'Qiraj",            lvl: '60', size: 20, hint: 'Silithus — AQ20' },
  { id: 3428, name: "Temple of Ahn'Qiraj",           lvl: '60', size: 40, hint: 'Silithus — AQ40 — C\'Thun' },
  { id: 3456, name: 'Naxxramas',                     lvl: '60', size: 40, hint: 'Eastern Plaguelands — Kel\'Thuzad' }
];

const ZONE_GROUPS = [
  { title: 'Eastern Kingdoms',            tag: 'Continent', zones: ALLIANCE_ZONES, accent: false },
  { title: 'Kalimdor',                    tag: 'Continent', zones: KALIMDOR_ZONES, accent: false }
];
---
<BaseLayout title="Zones, dungeons & raids — Emberstone Database">
  <Container size="lg" class="mt-10">
    <header>
      <h1 class="font-heading text-4xl tracking-tight text-ash-50">Zones, dungeons & raids</h1>
      <p class="mt-2 text-ash-100 max-w-2xl">
        The Classic 1.12.1 world catalogue — every open-world zone on both
        continents plus the full dungeon and raid list. Per-zone pages
        aggregate quests, NPCs, and instance encounters local to that area.
      </p>
    </header>

    {ZONE_GROUPS.map(g => (
      <section class="mt-12">
        <div class="flex items-end justify-between gap-4 mb-4">
          <div>
            <span class="text-[10px] uppercase tracking-widest text-ember-300">{g.tag}</span>
            <h2 class="font-heading text-2xl text-ash-50">{g.title}</h2>
          </div>
          <span class="text-xs text-ash-300 font-mono">{g.zones.length} zones</span>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {g.zones.map(z => (
            <a
              href={`/db/zones/${z.id}`}
              class="group rounded-md bg-bg-card backdrop-blur-sm border border-ember-500/[0.08] p-4
                     hover:bg-bg-raised hover:border-ember-500/[0.30] hover:shadow-glow
                     transition-all duration-300"
            >
              <div class="flex items-center justify-between text-[10px] uppercase tracking-widest text-ash-300">
                <span>Open world</span>
                <span class="text-ember-300">Lv {z.lvl}</span>
              </div>
              <div class="mt-2 text-ash-50 group-hover:text-ember-bright transition-colors">{z.name}</div>
              {z.hint && <div class="mt-1 text-xs text-ash-300">{z.hint}</div>}
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- ── Dungeons ─────────────────────────────────────────────── -->
    <section class="mt-16">
      <div class="flex items-end justify-between gap-4 mb-4">
        <div>
          <span class="text-[10px] uppercase tracking-widest text-ember-300">Instanced · 5-player</span>
          <h2 class="font-heading text-2xl text-ash-50">Dungeons</h2>
        </div>
        <span class="text-xs text-ash-300 font-mono">{DUNGEONS.length} dungeons</span>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {DUNGEONS.map(d => (
          <a
            href={`/db/zones/${d.id}`}
            class="group rounded-md bg-bg-card backdrop-blur-sm border border-ember-500/[0.12] p-4
                   hover:bg-bg-raised hover:border-ember-500/[0.40] hover:shadow-glow
                   transition-all duration-300"
          >
            <div class="flex items-center justify-between text-[10px] uppercase tracking-widest text-ash-300">
              <span class="text-ember-400">Dungeon · {d.size}-man</span>
              <span class="text-ember-300">Lv {d.lvl}</span>
            </div>
            <div class="mt-2 text-ash-50 group-hover:text-ember-bright transition-colors">{d.name}</div>
            {d.hint && <div class="mt-1 text-xs text-ash-300">{d.hint}</div>}
          </a>
        ))}
      </div>
    </section>

    <!-- ── Raids ────────────────────────────────────────────────── -->
    <section class="mt-16 mb-24">
      <div class="flex items-end justify-between gap-4 mb-4">
        <div>
          <span class="text-[10px] uppercase tracking-widest text-rarity-epic">Instanced · 10/20/40-player</span>
          <h2 class="font-heading text-2xl text-ash-50">Raids</h2>
        </div>
        <span class="text-xs text-ash-300 font-mono">{RAIDS.length} raids</span>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {RAIDS.map(r => (
          <a
            href={`/db/zones/${r.id}`}
            class="group rounded-md bg-bg-card backdrop-blur-sm p-4
                   transition-all duration-300
                   hover:bg-bg-raised hover:shadow-glow"
            style="border: 1px solid rgba(163, 53, 238, 0.18);"
          >
            <div class="flex items-center justify-between text-[10px] uppercase tracking-widest text-ash-300">
              <span class="text-rarity-epic">Raid · {r.size}-man</span>
              <span class="text-ember-300">Lv {r.lvl}</span>
            </div>
            <div class="mt-2 text-ash-50 group-hover:text-ember-bright transition-colors">{r.name}</div>
            {r.hint && <div class="mt-1 text-xs text-ash-300">{r.hint}</div>}
          </a>
        ))}
      </div>
    </section>
  </Container>
</BaseLayout>
