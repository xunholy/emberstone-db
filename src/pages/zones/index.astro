  { id: 14,  name: 'Durotar',                lvl: '1–10' },
  { id: 1637,name: 'Orgrimmar',              lvl: 'capital' },
  { id: 141, name: 'Teldrassil',             lvl: '1–10' },
  { id: 1657,name: 'Darnassus',              lvl: 'capital' },
  { id: 17,  name: 'The Barrens',            lvl: '10–25' },
  { id: 148, name: 'Darkshore',              lvl: '10–20' },
  { id: 331, name: 'Ashenvale',              lvl: '18–30' },
  { id: 1638,name: "Thunder Bluff",          lvl: 'capital' },
  { id: 406, name: 'Stonetalon Mountains',   lvl: '15–27' },
  { id: 405, name: 'Desolace',               lvl: '30–40' },
  { id: 357, name: 'Feralas',                lvl: '40–50' },
  { id: 400, name: 'Thousand Needles',       lvl: '25–35' },
  { id: 16,  name: 'Azshara',                lvl: '45–55' },
