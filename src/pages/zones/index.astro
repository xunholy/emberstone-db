  { id: 2057, name: 'Scholomance',                   lvl: '58–60', size: 5, hint: 'Western Plaguelands' },
  { id: 429,  name: 'Dire Maul (3 wings)',           lvl: '54–60', size: 5, hint: 'Feralas — East / West / North' }
