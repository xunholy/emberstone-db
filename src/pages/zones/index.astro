---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/layout/Container.astro';

// ── Classic 1.12.1 world catalogue ─────────────────────────────────
// Open-world zones grouped by continent, then instanced content by
// type. AreaIDs match the client's AreaTable.dbc so the per-zone page
// can later join against quest_template.ZoneOrSort (positive values
// are AreaIDs, negative values are QuestSort buckets) to roll up the
// content. Levels are the in-game level brackets, not strict caps.

type Zone = {
  id: number;
  name: string;
  /** Display-only level range. */
  lvl: string;
  /** Optional sub-zone hint (e.g. "Booty Bay" for STV). */
  hint?: string;
};
type Instance = Zone & {
  size: number;
  /** Optional designed party size (5/10/20/40). */
};

const ALLIANCE_ZONES: Zone[] = [
  { id: 12,  name: 'Elwynn Forest',          lvl: '1–10' },
  { id: 1519,name: 'Stormwind City',         lvl: 'capital' },
  { id: 38,  name: 'Loch Modan',             lvl: '10–20' },
  { id: 40,  name: 'Westfall',               lvl: '10–20' },
  { id: 1,   name: 'Dun Morogh',             lvl: '1–10' },
  { id: 1537,name: 'Ironforge',              lvl: 'capital' },
  { id: 85,  name: 'Tirisfal Glades (Alliance scout)', lvl: '1–10', hint: 'shared questing' },
  { id: 44,  name: 'Redridge Mountains',     lvl: '15–25' },
  { id: 10,  name: 'Duskwood',               lvl: '18–30' },
