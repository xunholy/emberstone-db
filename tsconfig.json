{
  "extends": "astro/tsconfigs/strict",
  "include": ["src/**/*", "scripts/**/*", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "verbatimModuleSyntax": false,
    "moduleResolution": "Bundler"
  }
}
